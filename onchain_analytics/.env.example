# ===========================================
# ACU Token Analytics - Environment Config
# ===========================================

# Database (TimescaleDB)
POSTGRES_USER=acu_user
POSTGRES_PASSWORD=acu_password
POSTGRES_DB=acu_analytics
DATABASE_URL=postgresql+asyncpg://acu_user:acu_password@localhost:5432/acu_analytics

# Redis
REDIS_URL=redis://localhost:6379/0

# BSC RPC Endpoints (use multiple for fallback)
BSC_RPC_PRIMARY=https://bsc-dataseed.binance.org
BSC_RPC_FALLBACK_1=https://bsc-dataseed1.binance.org
BSC_RPC_FALLBACK_2=https://rpc.ankr.com/bsc

# BscScan API (get free key at https://bscscan.com/apis)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ===========================================
# ACU Token Config
# ===========================================
ACU_TOKEN_ADDRESS=0x6ef2ffb38d64afe18ce782da280b300e358cfeaf
USDT_TOKEN_ADDRESS=0x55d398326f99059ff775485246999027b3197955
# PancakeSwap V3 ACU/USDT Pool (0.25% fee tier)
POOL_ADDRESS=0xbfEbc33B770a6261A945051087dB281fda8b8513

# Token decimals
ACU_DECIMALS=12
USDT_DECIMALS=18

# ===========================================
# Collector Settings
# ===========================================
# Starting block for historical sync (set to pool creation block)
START_BLOCK=0
# Batch size for fetching logs
BATCH_SIZE=1000
# Rate limit: requests per second
RPC_RATE_LIMIT=10

# ===========================================
# API Settings
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000

# ===========================================
# Celery Settings
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
